# Package name must match TOC so folder name is consistent for installs/updates
package-as: HorizonSuite

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

# Exclude CI, config, dev scripts, and marketing media under docs/ from the packaged addon
ignore:
  - HorizonSuiteBeta.toc
  - options/Mockups.lua
  - .github
  - .gitignore
  - .pkgmeta
  - scripts
  - docs # screenshots/GIFs for listings; not shipped in Curse/Wago zips
  - notes
  - "modules/*/notes"
  - pipeline.md
  - .cursor
  - .claude
  - .vscode
