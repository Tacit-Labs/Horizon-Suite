# Package name must match TOC so folder name is consistent for installs/updates
package-as: HorizonSuite

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

# Exclude CI, config, dev tooling, and marketing media from the packaged addon.
# BigWigs release.sh does not strip inline # comments on ignore list lines; keep "- path" alone.
ignore:
  - HorizonSuiteBeta.toc
  - options/Mockups.lua
  - .github
  - .gitignore
  - .pkgmeta
  - scripts
  - tools
  - docs
  - notes
  - "modules/*/notes"
  - pipeline.md
  - .cursor
  - .claude
  - .vscode
